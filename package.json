{
  "name": "financial-reporting-tool",
  "version": "1.0.0",
  "description": "Internal Financial Reporting Tool with conditional form logic",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "dev:client": "cd client && npm start",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "cd client && npm run build",
    "start": "node dist/server/index.js",
    "migrate": "ts-node src/server/database/migrations.ts",
    "seed": "ts-node src/server/database/seed.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.6",
    "puppeteer": "^21.5.2",
    "handlebars": "^4.7.8",
    "multer": "^1.4.5-lts.1",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/sqlite3": "^3.1.11",
    "@types/node": "^20.9.0",
    "@types/multer": "^1.4.11",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "financial",
    "reporting",
    "dashboard",
    "crud",
    "typescript"
  ],
  "author": "Financial Reporting Team",
  "license": "MIT"
}